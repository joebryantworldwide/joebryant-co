# Copy this file to .env.local and fill in what you have.

# — Sanity (site photography studio) —
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# — Joe Bryant | Access (client backend) —
# Admin sign-in at /access is joe@joebryant.co + this code (default: JOEADMIN)
ACCESS_ADMIN_CODE=
# Used in shareable prep-guide links; defaults to https://joebryant.co
NEXT_PUBLIC_SITE_URL=

# — Notifications (optional) —
# With a Resend API key (resend.com), "Message Joe" and booking requests
# email you instantly. Without it, everything still lands in /access/admin.
RESEND_API_KEY=
NOTIFY_EMAIL=joe@joebryant.co

# — Square payments —
# Sandbox by default. From the Square Developer dashboard → your app →
# Credentials (Sandbox), plus a sandbox Location ID. Switch SQUARE_ENV to
# "production" with production credentials to take real payments.
SQUARE_ENV=sandbox
SQUARE_APP_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# Publishable IDs for the in-app card form (safe to expose). Mirror the
# app id + location id above.
NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
# Production webhook only (Square can't reach localhost): set this to the
# signature key from the webhook you create at /api/square/webhook.
SQUARE_WEBHOOK_SIGNATURE_KEY=

# — SmugMug client galleries (optional) —
# Renders clients' real photos natively inside /access. Get keys at
# smugmug.com/app (Apply for an API Key), then authorize your own account
# once to obtain the access token + secret. See "Client galleries" in
# README. Until all four are set, the Gallery tab shows a preview grid.
SMUGMUG_API_KEY=
SMUGMUG_API_SECRET=
SMUGMUG_ACCESS_TOKEN=
SMUGMUG_ACCESS_SECRET=
